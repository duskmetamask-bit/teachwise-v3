# ─── Convex ──────────────────────────────────────────────────────────────
# Provision a new deployment: npx convex dev
# Copy the deployment URL into NEXT_PUBLIC_CONVEX_URL.
NEXT_PUBLIC_CONVEX_URL=

# ─── MiniMax (AI gateway) ────────────────────────────────────────────────
# Single API key covers all three modalities. Endpoints + model names are
# baked in as defaults but can be overridden per environment.
# Text:   https://api.minimax.io/anthropic/v1/messages    model MiniMax-M3
# Image:  https://api.minimax.io/v1/image_generation     model image-01
# TTS:    https://api.minimax.io/v1/t2a_v2               model speech-2.8-hd
# STT:    not available on MiniMax — deferred.
MINIMAX_API_KEY=
# MINIMAX_IMAGE_URL=
# MINIMAX_IMAGE_MODEL=
# MINIMAX_TTS_URL=
# MINIMAX_TTS_MODEL=

# ─── Clerk (Phase 4) ─────────────────────────────────────────────────────
# New isolated Clerk app, not the EMVY instance.
# Add in Phase 4 only — not needed for Phases 1-3.
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=

# ─── Convex ↔ Clerk integration (Phase 4) ─────────────────────────────────
# From Clerk dashboard → Webhooks → add Convex endpoint, copy signing secret.
CLERK_WEBHOOK_SECRET=
